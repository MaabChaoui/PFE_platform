<https://legal.dz/resource/law/2015-12-30/15-20#version_art_567_bis> a dzdoc:AmendmentEvent,
        dzdoc:LifecycleAssertion ;
    dzdoc:assertsTarget <https://legal.dz/resource/law/2015-12-30/15-20> ;
    dzdoc:confidenceScore 1.0 ;
    dzdoc:datePrecision "exact" ;
    dzdoc:evidenceText "يمكن أن تكون المساهمة في الشركة ذات المسؤولية المحدودة تقديم عمل ، تحدد كيفيات تقدير قيمته وما يخوله من أرباح ضمن القانون الأساسي للشركة ولا يدخل في تأسيس رأسمال الشركة."@ar ;
    dzdoc:isAuthoritative true ;
    dzdoc:isContradictory false ;
    dzdoc:operationType dzdoc:OpEnact ;
    dzdoc:producesVersion <https://legal.dz/resource/law/2015-12-30/15-20#version_art_567_bis_20151230_OpEnact_dfba23f5cd> ;
    dzdoc:replacementText "يمكن أن تكون المساهمة في الشركة ذات المسؤولية المحدودة تقديم عمل ، تحدد كيفيات تقدير قيمته وما يخوله من أرباح ضمن القانون الأساسي للشركة ولا يدخل في تأسيس رأسمال الشركة."@ar ;
    dzdoc:resolutionStatus "resolved" ;
    dzdoc:sourceArticle <https://legal.dz/resource/law/2015-12-30/15-20#art_567_bis> ;
    dzdoc:sourceDocument <https://legal.dz/resource/law/2015-12-30/15-20> ;
