<https://legal.dz/resource/law/2015-12-30/15-20#art_566_para_0> a dzdoc:Paragraph ;
    dzdoc:directlyContainedIn <https://legal.dz/resource/law/2015-12-30/15-20#art_566> ;
    dzdoc:position 0 ;
    dzdoc:text "يحدد رأسمال الشركة ذات المسؤولية المحدودة بحرية من طرف الشركاء في القانون الأساسي للشركة ويقسم إلى حصص ذات قيمة اسمية متساوية."@ar .

<https://legal.dz/resource/law/2015-12-30/15-20#art_566_para_1> a dzdoc:Paragraph ;
