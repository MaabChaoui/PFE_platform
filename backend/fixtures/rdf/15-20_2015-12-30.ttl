<https://legal.dz/resource/law/2015-12-30/15-20#version_art_590> a dzdoc:AmendmentEvent,
        dzdoc:LifecycleAssertion ;
    dzdoc:assertsTarget <https://legal.dz/resource/law/2015-12-30/15-20> ;
    dzdoc:confidenceScore 1.0 ;
    dzdoc:datePrecision "exact" ;
    dzdoc:evidenceText "لا يسوغ أن يتجاوز عدد الشركاء في الشركة ذات المسؤولية المحدودة خمسين (50) شريكا . وإذا أصبحت الشركة مشتملة على أكثر من خمسين (50) شريكا وجب تحويلها إلى شركة مساهمة في أجل سنة واحدة . وعند عدم القيام بذلك، تنحل الشركة ما لم يصبح عدد الشركاء في تلك الفترة من الزمن مساويا لخمسين (50) شريكا أو أقل."@ar ;
    dzdoc:isAuthoritative true ;
    dzdoc:isContradictory false ;
    dzdoc:operationType dzdoc:OpEnact ;
    dzdoc:producesVersion <https://legal.dz/resource/law/2015-12-30/15-20#version_art_590_20151230_OpEnact_6f333943e6> ;
    dzdoc:replacementText "لا يسوغ أن يتجاوز عدد الشركاء في الشركة ذات المسؤولية المحدودة خمسين (50) شريكا . وإذا أصبحت الشركة مشتملة على أكثر من خمسين (50) شريكا وجب تحويلها إلى شركة مساهمة في أجل سنة واحدة . وعند عدم القيام بذلك، تنحل الشركة ما لم يصبح عدد الشركاء في تلك الفترة من الزمن مساويا لخمسين (50) شريكا أو أقل."@ar ;
    dzdoc:resolutionStatus "resolved" ;
    dzdoc:sourceArticle <https://legal.dz/resource/law/2015-12-30/15-20#art_590> ;
