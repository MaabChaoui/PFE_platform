    dznorm:expressedIn <https://legal.dz/resource/law/1994-04-11/94-03#art_2> ;
    dznorm:position 0 ;
    dznorm:provisionText "ينشر هذا المرسوم التشريعي في الجريدة الرسمية للجمهورية الجزائرية الديمقراطية الشعبية."@ar ;
    dznorm:sourceArticle "art_2" .

